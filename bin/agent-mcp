#!/bin/sh
# generated by scripts/ensure-bin-executable.mjs
SCRIPT_DIR="$(CDPATH= cd -- "$(dirname "$0")" && pwd)"
SERVER_JS="$SCRIPT_DIR/../dist/server.js"

[ -x '/opt/homebrew/Cellar/bun/1.3.11/bin/bun' ] && exec '/opt/homebrew/Cellar/bun/1.3.11/bin/bun' "$SERVER_JS" "$@"
if command -v bun >/dev/null 2>&1; then exec bun "$SERVER_JS" "$@"; elif command -v node >/dev/null 2>&1; then exec node "$SERVER_JS" "$@"
else
  echo "agent-mcp requires bun or node in PATH" >&2
  exit 127
fi
