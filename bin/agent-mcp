#!/bin/sh
SOURCE="$0"
while [ -h "$SOURCE" ]; do
  LINK_DIR="$(CDPATH= cd -- "$(dirname "$SOURCE")" && pwd)"
  TARGET="$(readlink "$SOURCE")"
  case "$TARGET" in
    /*) SOURCE="$TARGET" ;;
    *) SOURCE="$LINK_DIR/$TARGET" ;;
  esac
done
SCRIPT_DIR="$(CDPATH= cd -- "$(dirname "$SOURCE")" && pwd)"
SERVER_JS="$SCRIPT_DIR/../dist/server.js"

if command -v bun >/dev/null 2>&1; then
  exec /usr/bin/env bun "$SERVER_JS" "$@"
fi

if command -v node >/dev/null 2>&1; then
  exec /usr/bin/env node "$SERVER_JS" "$@"
fi

echo "agent-mcp requires bun or node in PATH" >&2
exit 127
